{
  "info": {
    "_postman_id": "churcheden-auth-2026",
    "name": "ChurchEden Backend — Auth API",
    "description": "Authentication API for ChurchEden — manual email/password sign-up, Google OAuth, email verification, password reset, and session management.\n\n**Base URL:** `https://api.churcheden.app`\n\n**Auth flow (manual sign-up):**\n1. `POST /api/v1/auth/register` — creates account, sends OTP + welcome email\n2. `POST /api/v1/auth/verify-email` — verify with 6-digit OTP from email\n3. `POST /api/v1/auth/login` — sign in (blocked until email verified)\n4. `GET /api/v1/auth/me` — current user (Bearer token)\n5. `POST /api/v1/auth/refresh` — rotate tokens\n6. `POST /api/v1/auth/logout` — invalidate session\n\n**Google OAuth:**\n1. `GET /api/v1/auth/google/url` — get redirect URL\n2. Open `GET /api/v1/auth/google` in browser\n3. Callback redirects to `{FRONTEND_URL}/auth/callback?accessToken=...`\n\n**Variables:** `baseUrl`, `accessToken`, `refreshToken`, `testEmail`, `testPassword`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.churcheden.app" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "testEmail", "value": "you@yourchurch.com" },
    { "key": "testPassword", "value": "YourPassword123" },
    { "key": "otp", "value": "123456" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Verify the API server is running."
          }
        }
      ]
    },
    {
      "name": "Auth — Manual",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  pm.collectionVariables.set('testEmail', json.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Create a new account. Sends OTP verification email + welcome email. Returns access/refresh tokens."
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-email",
            "description": "Verify email with 6-digit OTP from inbox. Required before login."
          }
        },
        {
          "name": "Resend Verification OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/resend-verification",
            "description": "Resend verification OTP. Requires Bearer token."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Sign in with email/password. Returns 403 EMAIL_NOT_VERIFIED if email not verified."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/me",
            "description": "Get authenticated user profile."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.newAccessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.newRefreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "description": "Rotate access + refresh tokens."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "description": "Invalidate refresh token and clear session cookies."
          }
        }
      ]
    },
    {
      "name": "Auth — Password Reset",
      "item": [
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password",
            "description": "Send password reset email. Always returns 200 (silent fail if email unknown)."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password",
            "description": "Reset password using token from email link."
          }
        }
      ]
    },
    {
      "name": "Auth — Google OAuth",
      "item": [
        {
          "name": "Get Google Auth URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/google/url",
            "description": "Returns the URL to redirect the browser to for Google sign-in."
          }
        },
        {
          "name": "Google OAuth (open in browser)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/auth/google",
            "description": "Open this URL in a browser to start Google OAuth. Callback: /api/v1/auth/google/callback → redirects to frontend /auth/callback?accessToken=..."
          }
        }
      ]
    }
  ]
}
