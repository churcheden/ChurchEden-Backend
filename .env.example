# =====================================================
# SERVER CONFIGURATION
# Used in: src/env.ts, src/server.ts, src/middleware/errorHandler.middleware.ts
# =====================================================
PORT=3000
NODE_ENV=development
APP_STAGE=dev
# APP_STAGE options: production | dev | test

# =====================================================
# DATABASE (Prisma + Neon adapter)
# Used in: src/env.ts, src/config/prisma.ts, prisma.config.ts
# =====================================================
DATABASE_URL=postgresql://username:password@localhost:5432/churcheden_db

# =====================================================
# SECURITY & AUTHENTICATION
# Used in: src/utils/password.ts, src/utils/jwt.ts, src/middleware/auth.middleware.ts
# =====================================================
BCRYPT_ROUNDS=12
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_here_minimum_32_chars
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_here_minimum_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# =====================================================
# FRONTEND
# Used in: src/controllers/authController.ts, src/routes/authRoutes.ts, src/services/email.service.ts, src/webhooks/paystack.webhooks.ts
# =====================================================
FRONTEND_URL=http://localhost:5173

# =====================================================
# GOOGLE OAUTH
# Used in: src/config/passport.ts
# =====================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# =====================================================
# EMAIL (Resend)
# Used in: src/services/email.service.ts
# =====================================================
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# =====================================================
# REDIS (Upstash)
# Used in: src/config/redis.ts (rate limiting + cache), src/config/redisTcp.ts
# Local: redis://localhost:6379
# Upstash: rediss://default:TOKEN@HOST.upstash.io:6379
# =====================================================
REDIS_URL=rediss://default:your_upstash_token@your-host.upstash.io:6379
REDIS_TCP_URL=rediss://default:your_upstash_token@your-host.upstash.io:6379

# =====================================================
# CLOUDFLARE R2 (S3-compatible storage)
# Used in: src/config/cloudflare.ts
# S3 endpoint from bucket Settings → General → S3 API
# API keys from R2 overview → Manage R2 API Tokens
# =====================================================
CLOUDFLARE_R2_ACCESS_KEY_ID=your_cloudflare_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_cloudflare_r2_secret_access_key
CLOUDFLARE_R2_ENDPOINT=https://133b689f126ad191dd9ef70f76678f00.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=eden-bucket
CLOUDFLARE_R2_PUBLIC_URL=https://pub-799159c566de4a8a8600bc057067ab69.r2.dev

# =====================================================
# PAYSTACK (payments + webhooks)
# Used in: src/services/payment.service.ts, src/webhooks/paystack.webhooks.ts, src/controllers/paymentController.ts
# =====================================================
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PLAN_CODE=PLN_your_plan_code
SUBSCRIPTION_AMOUNT_KOBO=2000

# =====================================================
# GOOGLE GEMINI (embeddings + AI features)
# Used in: src/services/embedding.service.ts
# =====================================================
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# =====================================================
# GOOGLE GEMINI (embeddings + AI features)
# Used in: src/services/embedding.service.ts
# =====================================================
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here
